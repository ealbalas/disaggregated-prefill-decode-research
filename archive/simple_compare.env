# configs/simple_compare.env
# Simple colocated vs disaggregated comparison experiment.
# Input length is the independent variable (256 → 8096, 4 points).
# Output length is fixed at 256.

# ── Colocated instance ─────────────────────────────────────────────────────
COLOCATED_PORT=8300
COLOCATED_GPU=0

# ── Proxy (for disaggregated runs) ─────────────────────────────────────────
PROXY_PORT=8192

# ── Disaggregated ratios to test (must match configs/ratios/ filenames) ────
RATIOS=(1p1d)

# ── Sweep dimensions ────────────────────────────────────────────────────────
INPUT_LENS=(256 1024 4096)
OUTPUT_LENS=(256)
REQUEST_RATES=(2 10)
CONCURRENCIES=(16)

# ── Fixed benchmark params ──────────────────────────────────────────────────
NUM_PROMPTS=50
BURSTINESS=1.0

# ── Goodput SLOs (ms) ───────────────────────────────────────────────────────
SLO_TTFT=500
SLO_TPOT=50
SLO_E2EL=5000
