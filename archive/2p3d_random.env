# configs/2p3d_random.env
# 2 prefill + 3 decode

# ── Proxy ─────────────────────────────────────────────────────────────────────
PROXY_PORT=8192

# ── Prefill instances ─────────────────────────────────────────────────────────
PREFILL_PORTS=(8100 8101)
PREFILL_GPUS=(0 1)
PREFILL_SIDE_CHANNELS=(5600 5601)

# ── Decode instances ──────────────────────────────────────────────────────────
DECODE_PORTS=(8200 8201 8202)
DECODE_GPUS=(2 3 4)
DECODE_SIDE_CHANNELS=(5700 5701 5702)

# ── Benchmark params ──────────────────────────────────────────────────────────
INPUT_LEN=1024
OUTPUT_LEN=1024
REQUEST_RATE=2
NUM_PROMPTS=50
BURSTINESS=10

# ── Goodput SLOs (ms) ─────────────────────────────────────────────────────────
SLO_TTFT=500
SLO_TPOT=50
SLO_E2EL=5000

# ── Metadata tag ──────────────────────────────────────────────────────────────
TAG="2p3d_random_${INPUT_LEN}x${OUTPUT_LEN}"
