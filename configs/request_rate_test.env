# configs/request_rate_test.env
# Request rate sweep: fixed input/output/concurrency, varying request rate.
# Colocated baseline vs disaggregated ratios at 1024-token input, 256-token output.

# ── Colocated instance ─────────────────────────────────────────────────────
COLOCATED_PORT=8300
COLOCATED_GPU=0

# ── Proxy (for disaggregated runs) ─────────────────────────────────────────
PROXY_PORT=8192

# ── Disaggregated ratios to test (must match configs/ratios/ filenames) ────
RATIOS=(1p1d 1p2d 2p1d)

# ── Sweep dimensions ────────────────────────────────────────────────────────
INPUT_LENS=(1024)
OUTPUT_LENS=(256)
REQUEST_RATES=(2 4 8 10)
CONCURRENCIES=(32)

# ── Fixed benchmark params ──────────────────────────────────────────────────
NUM_PROMPTS=100
BURSTINESS=1.0

# ── Goodput SLOs (ms) ───────────────────────────────────────────────────────
SLO_TTFT=500
SLO_TPOT=50
SLO_E2EL=5000
