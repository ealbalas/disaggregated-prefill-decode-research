# configs/principled_ratio_comparison.env
#
# Principled ratio comparison: all 5 P:D ratios plus colocated baseline, at
# operating points and SLOs derived from measured data.
#
# Rate rationale (from saturation_sweep results, plateau ~4.5 req/s):
#   rate=2 ≈ 44% of saturation — sub-saturation, measures latency under moderate load
#   rate=4 ≈ 89% of saturation — near-saturation, stresses system without overflow
#
# SLO rationale (2× colocated unloaded latency from existing baseline runs):
#   SLO_TTFT = 2 × 57ms ≈ 120ms  (note: disagg baseline overhead ~150ms, making this
#                                   a "colocated parity" threshold that reveals overhead cost)
#   SLO_TPOT = 2 × 19ms ≈ 40ms
#   SLO_E2EL is per-workload and injected by the experiment script — see
#             experiments/principled_ratio_comparison.sh for the per-workload override.
#
# 64x1024 is excluded: its unloaded E2EL is ~20,500ms; no config can meet a
# meaningful SLO for that workload with the current Nixl overhead.
#
# INPUT_LENS and OUTPUT_LENS are index-paired (not crossed).

# ── Colocated instance ─────────────────────────────────────────────────────
COLOCATED_PORT=8300
COLOCATED_GPU=0

# ── Proxy (for disaggregated runs) ─────────────────────────────────────────
PROXY_PORT=8192

# ── Disaggregated ratios to test ───────────────────────────────────────────
RATIOS=(1p1d 1p2d 1p3d 2p1d 3p1d)

# ── Sweep dimensions (INPUT_LENS[i] paired with OUTPUT_LENS[i]) ─────────────
INPUT_LENS=(1024 256 64)
OUTPUT_LENS=(64   256 256)

# Derived operating points: ~50% and ~90% of measured saturation
REQUEST_RATES=(2 4)
CONCURRENCIES=(32)

# ── Fixed benchmark params ──────────────────────────────────────────────────
NUM_PROMPTS=200
BURSTINESS=1.0

# ── Goodput SLOs (ms) — derived from 2× colocated unloaded latency ──────────
SLO_TTFT=120
SLO_TPOT=40
# SLO_E2EL is overridden per-workload in the experiment script:
#   1024x64  → 3000ms  (2 × 1509ms observed unloaded E2EL)
#   256x256  → 10000ms (2 × 4762ms observed unloaded E2EL)
#   64x256   → 10000ms (similar to balanced)
SLO_E2EL=10000
