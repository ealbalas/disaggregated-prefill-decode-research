# configs/baseline_random.env
# 1 prefill + 1 decode (original baseline).
# Arrays are space-separated. Must have one entry per instance.

# ── Proxy ─────────────────────────────────────────────────────────────────────
PROXY_PORT=8192

# ── Prefill instances ─────────────────────────────────────────────────────────
PREFILL_PORTS=(8100)
PREFILL_GPUS=(0)
PREFILL_SIDE_CHANNELS=(5600)

# ── Decode instances ──────────────────────────────────────────────────────────
DECODE_PORTS=(8200)
DECODE_GPUS=(1)
DECODE_SIDE_CHANNELS=(5700)

# ── Benchmark params ──────────────────────────────────────────────────────────
INPUT_LEN=1024
OUTPUT_LEN=1024
REQUEST_RATE=2
NUM_PROMPTS=50
BURSTINESS=10

# ── Goodput SLOs (ms) ─────────────────────────────────────────────────────────
SLO_TTFT=500
SLO_TPOT=50
SLO_E2EL=5000

# ── Metadata tag (shows up in results filenames) ──────────────────────────────
TAG="baseline_random_${INPUT_LEN}x${OUTPUT_LEN}"
