# configs/sweep_compare.env
# Colocated vs disaggregated comparison experiment.
# Input length is the independent variable (256 → 10000, 5 points).
# Output length is fixed at 256.

# ── Colocated instance ─────────────────────────────────────────────────────
COLOCATED_PORT=8300
COLOCATED_GPU=0

# ── Proxy (for disaggregated runs) ─────────────────────────────────────────
PROXY_PORT=8192

# ── Disaggregated ratios to test (must match configs/ratios/ filenames) ────
RATIOS=(1p1d 2p1d 3p1d)

# ── Sweep dimensions ────────────────────────────────────────────────────────
INPUT_LENS=(256 512 2048 5120 10000)
OUTPUT_LENS=(256)
REQUEST_RATES=(2 20)
CONCURRENCIES=(16)

# ── Fixed benchmark params ──────────────────────────────────────────────────
NUM_PROMPTS=100
BURSTINESS=10

# ── Goodput SLOs (ms) ───────────────────────────────────────────────────────
SLO_TTFT=500
SLO_TPOT=50
SLO_E2EL=5000
