# configs/sweep.env
# All values to sweep over. Each combo of ratio x input x output x rate x concurrency
# will be run as a separate benchmark. Comment out values you don't need.

# ── Proxy ─────────────────────────────────────────────────────────────────────
PROXY_PORT=8192

# ── Ratios to test (must match filenames in configs/ratios/) ──────────────────
RATIOS=(1p3d)

# ── Sweep dimensions ──────────────────────────────────────────────────────────
INPUT_LENS=(256 1024 4096 10000)
OUTPUT_LENS=(256 1024 4096 10000)
REQUEST_RATES=(2 8)
CONCURRENCIES=(8 32)

# ── Fixed benchmark params ────────────────────────────────────────────────────
NUM_PROMPTS=50
BURSTINESS=10

# ── Goodput SLOs (ms) ─────────────────────────────────────────────────────────
SLO_TTFT=500
SLO_TPOT=50
SLO_E2EL=5000
