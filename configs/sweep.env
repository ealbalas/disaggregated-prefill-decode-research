# configs/sweep.env
# All values to sweep over. Each combo of ratio x input x output x rate x concurrency
# will be run as a separate benchmark. Comment out values you don't need.

# ── Proxy ─────────────────────────────────────────────────────────────────────
PROXY_PORT=8192

# ── Ratios to test (must match filenames in configs/ratios/) ──────────────────
RATIOS=(1p1d 1p2d 1p3d 2p1d 3p1d)

# ── Sweep dimensions ──────────────────────────────────────────────────────────
INPUT_LENS=(256 512 1024 2048 4096 6144 8192 10000)
OUTPUT_LENS=(256 512 1024 2048 4096 6144 8192 10000)
REQUEST_RATES=(1 2 4 8)
CONCURRENCIES=(4 8 16 32)

# ── Fixed benchmark params ────────────────────────────────────────────────────
NUM_PROMPTS=50
BURSTINESS=10

# ── Goodput SLOs (ms) ─────────────────────────────────────────────────────────
SLO_TTFT=500
SLO_TPOT=50
SLO_E2EL=5000
