# configs/ratio_characterization.env
# Ratio characterization: all 5 P:D ratios across three workload archetypes.
# Tests prefill-heavy (1024x64), balanced (256x256), and decode-heavy (64x1024)
# to identify which ratio is optimal per workload type.
# INPUT_LENS and OUTPUT_LENS are index-paired (not crossed).

# ── Colocated instance ─────────────────────────────────────────────────────
COLOCATED_PORT=8300
COLOCATED_GPU=0

# ── Proxy (for disaggregated runs) ─────────────────────────────────────────
PROXY_PORT=8192

# ── Disaggregated ratios to test (must match configs/ratios/ filenames) ────
RATIOS=(1p1d 1p2d 1p3d 2p1d 3p1d)

# ── Sweep dimensions (INPUT_LENS[i] paired with OUTPUT_LENS[i]) ─────────────
INPUT_LENS=(1024 256 64)
OUTPUT_LENS=(64 256 1024)
REQUEST_RATES=(2 10)
CONCURRENCIES=(32)

# ── Fixed benchmark params ──────────────────────────────────────────────────
NUM_PROMPTS=100
BURSTINESS=1.0

# ── Goodput SLOs (ms) ───────────────────────────────────────────────────────
SLO_TTFT=500
SLO_TPOT=50
SLO_E2EL=5000
