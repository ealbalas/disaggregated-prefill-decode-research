# configs/max_throughput.env
#
# Max throughput characterization: isolates prefill and decode capacity by
# sweeping lengths and rates with the opposing stage minimized.
#
# Prefill phase: output_len=1, sweep input_len and rate.
#   TTFT ≈ prefill time (decode negligible). Saturation point = rate at which
#   request_throughput < rate (achieved < offered). Offered load = rate × input_len.
#
# Decode phase: input_len=64 (fixed, minimal prefill cost), sweep output_len and rate.
#   Saturation detected the same way. Offered load = rate × output_len.
#
# Rate range (1–32 req/s) brackets saturation across all lengths: short sequences
# saturate at high rates, long sequences saturate at low rates.

# ── Colocated instance ────────────────────────────────────────────────────────
COLOCATED_PORT=8300
COLOCATED_GPU=0

# ── Proxy (for disaggregated runs) ───────────────────────────────────────────
PROXY_PORT=8192

# ── Disaggregated ratios to test ─────────────────────────────────────────────
RATIOS=(1p1d)

# ── Prefill sweep (all output_len=1, index-paired) ───────────────────────────
PREFILL_INPUT_LENS=(64  128  256  512  1024)
PREFILL_OUTPUT_LENS=(1   1    1    1    1)

# ── Decode sweep (all input_len=64, index-paired) ────────────────────────────
DECODE_INPUT_LENS=(64   64   64   64   64)
DECODE_OUTPUT_LENS=(64  128  256  512  1024)

# ── Sweep rates ──────────────────────────────────────────────────────────────
REQUEST_RATES=(1 2 4 8 16 32)
CONCURRENCIES=(64)

# ── Fixed benchmark params ───────────────────────────────────────────────────
NUM_PROMPTS=200
BURSTINESS=1.0

# ── Goodput SLOs (wide — saturation curve focus, not goodput) ────────────────
SLO_TTFT=5000
SLO_TPOT=1000
SLO_E2EL=30000
