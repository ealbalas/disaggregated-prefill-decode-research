# configs/capacity_sweep.env
#
# Adaptive capacity sweep: finds the maximum input/output length the server
# can sustain at a given throughput target.
#
# Phase 1 — Prefill sweep: output_len=1, doubles input_len each run until
#   output_throughput drops below TARGET_TOK_PER_S.
#   Result: max input length the server can sustain.
#
# Phase 2 — Decode sweep: fixes input_len from phase 1, doubles output_len
#   each run until output_throughput drops below TARGET_TOK_PER_S.
#   Result: max output length the server can sustain.

# ── Phase control ─────────────────────────────────────────────────────────────
RUN_COLOCATED=true
RUN_DISAGG=true

# ── Colocated instance ────────────────────────────────────────────────────────
COLOCATED_PORT=8300
COLOCATED_GPU=0

# ── Proxy (for disaggregated runs) ───────────────────────────────────────────
PROXY_PORT=8192
RATIOS=(1p1d)

# ── Throughput target ─────────────────────────────────────────────────────────
# Stop doubling when measured output_throughput (tok/s) drops below this.
TARGET_TOK_PER_S=100

# ── Fixed request parameters ──────────────────────────────────────────────────
REQUEST_RATE=4
CONCURRENCY=32

# ── Prefill sweep bounds ──────────────────────────────────────────────────────
START_INPUT_LEN=64
MAX_INPUT_LEN=4096          # Hard cap — must not exceed --max-model-len

# ── Decode sweep bounds ───────────────────────────────────────────────────────
START_OUTPUT_LEN=64
MAX_OUTPUT_LEN=2048

# ── Fixed benchmark params ────────────────────────────────────────────────────
NUM_PROMPTS=200
BURSTINESS=1.0

# ── Goodput SLOs (wide — throughput focus, not goodput) ──────────────────────
SLO_TTFT=5000
SLO_TPOT=1000
SLO_E2EL=30000
