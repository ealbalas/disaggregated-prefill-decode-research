# configs/kv_transfer_isolation.env
#
# KV transfer isolation: quantify Nixl KV transfer overhead as a function of
# input length (proxy for KV cache size). With output_len=1, decode is negligible
# so TTFT ≈ prefill_time + transfer_time. Subtracting the colocated TTFT isolates
# the transfer cost per input length.
#
# Rate rationale: rate=1 is ~22% of saturation, keeping the queue near-empty so
# TTFT reflects intrinsic latency rather than queueing delay.

# ── Colocated instance ─────────────────────────────────────────────────────
COLOCATED_PORT=8300
COLOCATED_GPU=0

# ── Proxy (for disaggregated runs) ─────────────────────────────────────────
PROXY_PORT=8192

# ── Disaggregated ratios to test ───────────────────────────────────────────
RATIOS=(1p1d)

# ── Sweep dimensions ────────────────────────────────────────────────────────
INPUT_LENS=(64 128 256 512 1024)
OUTPUT_LENS=(1  1   1   1   1)

# Single low rate to eliminate queueing from latency measurement
REQUEST_RATES=(1)
CONCURRENCIES=(32)

# ── Fixed benchmark params ──────────────────────────────────────────────────
NUM_PROMPTS=200
BURSTINESS=1.0

# ── Goodput SLOs (ms) — wide; SLO is not the focus here ────────────────────
SLO_TTFT=5000
SLO_TPOT=1000
SLO_E2EL=10000
