# configs/throughput_comparison.env
#
# Throughput comparison across workloads and configs.
# Runs every (input_len × output_len) combination for each config
# (colocated baseline + disaggregated ratios) at a fixed set of request rates.
# Use this to see how each setup performs across different sequence length mixes.

# ── Phase control ─────────────────────────────────────────────────────────────
RUN_COLOCATED=true
RUN_DISAGG=true

# ── Colocated instance ────────────────────────────────────────────────────────
COLOCATED_PORT=8300
COLOCATED_GPU=0

# ── Proxy (for disaggregated runs) ───────────────────────────────────────────
PROXY_PORT=8192

# ── Disaggregated ratios to test ─────────────────────────────────────────────
RATIOS=(1p1d)

# ── Workload grid (every input × every output is benchmarked) ─────────────────
INPUT_LENS=(64 256 512 1024)
OUTPUT_LENS=(64 256 512 1024)

# ── Sweep rates and concurrency ───────────────────────────────────────────────
REQUEST_RATES=(4 8)
CONCURRENCIES=(32)

# ── Fixed benchmark params ───────────────────────────────────────────────────
NUM_PROMPTS=200
BURSTINESS=1.0

# ── Goodput SLOs ─────────────────────────────────────────────────────────────
SLO_TTFT=5000
SLO_TPOT=1000
SLO_E2EL=30000
