# configs/saturation_sweep.env
#
# Saturation sweep: find the request rate at which throughput plateaus for each
# workload shape. Only colocated and 1p1d are tested — the goal is characterizing
# the workload's saturation point, not ranking all ratios.
#
# INPUT_LENS and OUTPUT_LENS are index-paired (not crossed).
#
# Rate rationale: existing data shows plateau at ~4.5 req/s for 256-output workloads.
# Rates 1–6 bracket the plateau on both sides with enough resolution to fit a curve.

# ── Colocated instance ─────────────────────────────────────────────────────
COLOCATED_PORT=8300
COLOCATED_GPU=0

# ── Proxy (for disaggregated runs) ─────────────────────────────────────────
PROXY_PORT=8192

# ── Disaggregated ratios to test ───────────────────────────────────────────
RATIOS=(1p1d)

# ── Sweep dimensions (INPUT_LENS[i] paired with OUTPUT_LENS[i]) ─────────────
INPUT_LENS=(1024 256 256)
OUTPUT_LENS=(64   256 128)

# Fine-grained rates bracketing the known ~4.5 req/s plateau
REQUEST_RATES=(1 2 3 4 5 6)
CONCURRENCIES=(32)

# ── Fixed benchmark params ──────────────────────────────────────────────────
NUM_PROMPTS=200
BURSTINESS=1.0

# ── Goodput SLOs (ms) — intentionally wide; saturation curve, not goodput ───
SLO_TTFT=1000
SLO_TPOT=100
SLO_E2EL=20000
